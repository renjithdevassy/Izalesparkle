@page "/forgot-password"
@inject IApiClient Api
@inject NavigationManager Nav

<PageTitle>Forgot Password — Izale Sparkle</PageTitle>

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-brand">
            <a href="/" class="auth-logo">Izale <span class="gold">✦</span> Sparkle</a>
            <div class="auth-tagline">Where Every Look Sparkles</div>
        </div>

        <h1 class="auth-title">Forgot Password</h1>
        <p class="auth-subtitle">Enter your email and we'll send you a reset link</p>

        @if (!string.IsNullOrEmpty(InfoMsg))
        {
            <div class="auth-success">✓ @InfoMsg</div>
        }
        else
        {
            @if (!string.IsNullOrEmpty(ErrorMsg))
            {
                <div class="auth-error">⚠️ @ErrorMsg</div>
            }

            <div class="auth-form">
                <div class="auth-field">
                    <label>Email Address</label>
                    <input type="email" inputmode="email" autocomplete="email"
                           @bind="Email" placeholder="your@email.com"
                           @onkeydown="OnKeyDown"
                           class="@(ShowErr && string.IsNullOrWhiteSpace(Email) ? "field-error" : "")" />
                </div>

                <button class="auth-submit-btn" @onclick="Submit" disabled="@Loading">
                    @(Loading ? "Sending…" : "Send Reset Link ✦")
                </button>
            </div>
        }

        <div class="auth-links" style="justify-content:center">
            <a href="/login">← Back to Sign In</a>
        </div>
    </div>
</div>

@code {
    string Email    = "";
    string ErrorMsg = "";
    string InfoMsg  = "";
    bool   Loading  = false;
    bool   ShowErr  = false;

    async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await Submit();
    }

    async Task Submit()
    {
        ShowErr  = false;
        ErrorMsg = "";

        if (string.IsNullOrWhiteSpace(Email))
        { ShowErr = true; ErrorMsg = "Please enter your email address."; return; }

        Loading = true;
        try
        {
            var result = await Api.ForgotPasswordAsync(Email.Trim());
            // The API always responds the same way so we never reveal whether the account exists.
            InfoMsg = result?.Message
                ?? "If an account exists for that email, a password reset link has been sent.";
        }
        catch { ErrorMsg = "Unable to connect. Please try again."; }
        finally { Loading = false; }
    }
}
