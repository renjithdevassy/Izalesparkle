@page "/about"
@inject IApiClient Api

<PageTitle>Our Story — Izale Sparkle</PageTitle>

<!-- HERO -->
<div class="about-hero">
    <div class="ah-img">
        <img src="https://images.unsplash.com/photo-1573408301185-9519f94bf22b?w=1200&q=80" alt="Our Atelier" />
    </div>
    <div class="ah-content">
        <div class="ah-tag">Our Story</div>
        <h1 class="ah-title">Where Craft<br /><em>Becomes Sparkle.</em></h1>
        <p class="ah-body">Founded with a single belief — that fine jewellery should make every woman feel extraordinary. Where Every Look Sparkles isn't just our tagline; it's our promise to every client.</p>
        <a href="#bespoke" class="btn btn-outline-light">Bespoke Service</a>
    </div>
</div>

<!-- NUMBER STRIP -->
<div class="numbers-bar">
    @foreach (var n in NumberStats)
    {
        <div class="nb-item">
            <div class="nb-num">@n.Num</div>
            <div class="nb-label">@n.Label</div>
        </div>
    }
</div>

<!-- HISTORY / TIMELINE -->
<section class="section bg-cream">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:6rem;align-items:start;@MobileGrid">
        <div>
            <span class="section-tag">✦ History ✦</span>
            <h2 class="section-title" style="text-align:left;margin-bottom:1rem">Our Sparkle <em>Journey</em></h2>
            <div class="sparkle-divider" style="justify-content:flex-start;margin-left:0"><span>✦</span></div>
            <p style="font-size:0.8rem;color:var(--warm-gray);line-height:1.9;margin-top:1.5rem;font-weight:300">
                From a passion for fine jewellery to a brand loved by thousands, every step of our journey has been shaped by one purpose: to make every look sparkle.
            </p>
            <img src="https://images.unsplash.com/photo-1608042314453-ae338d9c6ad1?w=600&q=80"
                 alt="Atelier"
                 style="width:100%;margin-top:2rem;height:300px;object-fit:cover;border:1px solid var(--border)" />
        </div>
        <div class="timeline">
            @foreach (var t in TimelineItems)
            {
                <div class="tl-item">
                    <div class="tl-dot"></div>
                    <div class="tl-year">@t.Year</div>
                    <div class="tl-title">@t.Title</div>
                    <div class="tl-body">@t.Body</div>
                </div>
            }
        </div>
    </div>
</section>

<!-- VALUES -->
<section class="section bg-white" id="ethics">
    <div class="section-head">
        <span class="section-tag">✦ Values ✦</span>
        <h2 class="section-title">What Makes Us <em>Sparkle</em></h2>
        <div class="sparkle-divider"><span>✦</span></div>
    </div>
    <div class="values-grid">
        @foreach (var v in Values)
        {
            <div class="val-card">
                <div class="val-icon">@v.Icon</div>
                <div class="val-title">@v.Title</div>
                <div class="val-body">@v.Body</div>
            </div>
        }
    </div>
</section>

<!-- TEAM -->
<section class="section bg-cream">
    <div class="section-head">
        <span class="section-tag">✦ The People ✦</span>
        <h2 class="section-title">Meet the <em>Artisans</em></h2>
        <div class="sparkle-divider"><span>✦</span></div>
    </div>
    <div class="team-grid">
        @foreach (var m in Team)
        {
            <div class="team-member">
                <img src="@m.Img" alt="@m.Name" class="team-img" loading="lazy" />
                <div class="team-name">@m.Name</div>
                <div class="team-role">@m.Role</div>
                <div class="team-bio">@m.Bio</div>
            </div>
        }
    </div>
</section>

<!-- BESPOKE SERVICE -->
<div class="bespoke-section" id="bespoke">
    <div class="bs-content">
        <span class="section-tag">✦ Bespoke ✦</span>
        <h2 class="section-title" style="text-align:left;margin-bottom:1rem">Your Vision,<br /><em>Our Sparkle.</em></h2>
        <div class="sparkle-divider" style="justify-content:flex-start;margin-left:0"><span>✦</span></div>
        <p style="font-size:0.8rem;color:var(--warm-gray);line-height:1.9;margin:1.5rem 0 2rem;font-weight:300">
            From engagement rings to anniversary gifts, our bespoke service brings your vision to life. Work one-on-one with our jewellers from first sketch to final sparkle.
        </p>
        @foreach (var (s, i) in BespokeSteps.Select((x,i)=>(x,i)))
        {
            <div class="bespoke-step">
                <div class="bs-num">0@(i+1)</div>
                <div>
                    <h4 class="bs-step-title">@s.Title</h4>
                    <p class="bs-step-body">@s.Body</p>
                </div>
            </div>
        }
        <a href="/contact" class="btn btn-dark" style="margin-top:2rem">Book a Consultation</a>
    </div>
    <div class="bs-img">
        <img src="https://images.unsplash.com/photo-1489367874814-848688f878e6?w=900&q=80" alt="Bespoke" />
    </div>
</div>

<!-- NEWSLETTER -->
<div class="newsletter-strip">
    <h3>Join the <em>Sparkle</em> Circle</h3>
    <p>Early access to new arrivals, exclusive events & jewellery care tips.</p>
    <div class="newsletter-form">
        <input class="newsletter-input" type="email" placeholder="Your email address" @bind="Email" />
        <button class="newsletter-submit" @onclick="Subscribe">Subscribe</button>
    </div>
    @if (Subscribed)
    {
        <p style="color:#f0d080;margin-top:0.8rem;font-size:0.8rem">✦ Welcome to the Sparkle Circle!</p>
    }
</div>

@code {
    string Email = "";
    bool Subscribed = false;
    string MobileGrid = "";

    record StatItem(string Num, string Label);
    record TimelineItem(string Year, string Title, string Body);
    record ValueItem(string Icon, string Title, string Body);
    record TeamMember(string Name, string Role, string Bio, string Img);
    record BespokeStep(string Title, string Body);

    List<StatItem> NumberStats = new()
    {
        new("200+",  "Unique Pieces"),
        new("12K+",  "Happy Clients"),
        new("100%",  "Conflict-Free"),
        new("18K",   "Gold Only"),
    };

    List<TimelineItem> TimelineItems = new()
    {
        new("The Beginning",  "Born from a Love of Sparkle",     "Izale Sparkle was founded with one belief: every woman deserves to shine. Our first collection sold out in days, and we never looked back."),
        new("First Year",     "Conflict-Free Pledge",            "We committed to 100% conflict-free sourcing from day one, partnering with certified suppliers who share our values across the globe."),
        new("Growing",        "Bespoke Service Launches",        "Our bespoke consultation service launches, allowing clients to work one-on-one with our jewellers to create the piece of their dreams."),
        new("Online",         "Global Reach",                    "Izale Sparkle goes online, bringing our collections to clients across the UK and worldwide. Free international shipping added for all orders."),
        new("2024",           "The Sparkle Collection",          "Our most ambitious collection yet — 32 original designs featuring Canadian-certified diamonds and Colombian emeralds."),
    };

    List<ValueItem> Values = new()
    {
        new("💎", "Uncompromising Quality",  "We use only hallmarked 18K gold and certified gemstones. Every piece is inspected to our exacting standards before it leaves our hands."),
        new("🌿", "Ethical Sourcing",        "100% conflict-free diamonds and gemstones, certified by the Kimberley Process. Fairtrade gold from responsible, traceable mines."),
        new("✨", "Every Look Sparkles",     "We believe jewellery should make you feel extraordinary. Every piece is crafted not just to be beautiful, but to make you truly shine."),
    };

    List<TeamMember> Team = new()
    {
        new("Isabella Hart",    "Creative Director",  "With 20 years crafting fine jewellery for clients worldwide, Isabella leads every design with an eye for timeless elegance and modern refinement.", "https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=600&q=80"),
        new("Marcus Chen",      "Head Gemologist",    "GIA Graduate Gemologist with 15 years sourcing exceptional stones across four continents. Every gem selected is a testament to his expertise.",       "https://images.unsplash.com/photo-1500648767791-00dcc994a43e?w=600&q=80"),
        new("Priya Nair",       "Master Goldsmith",   "Trained at the Birmingham School of Jewellery, Priya's hands have crafted over 2,500 individual pieces. Her precision is unmatched.",              "https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=600&q=80"),
    };

    List<BespokeStep> BespokeSteps = new()
    {
        new("Consultation",         "A private session to discuss your vision, style, and budget with our creative director."),
        new("Design & Sketch",      "Hand-drawn designs and 3D renders prepared for your approval before crafting begins."),
        new("Handcrafted for You",  "Your piece is crafted over 4–6 weeks with regular progress updates and photographs."),
        new("Delivered with Love",  "Presented in our signature Izale Sparkle box with a certificate and lifetime guarantee."),
    };

    async Task Subscribe()
    {
        if (string.IsNullOrWhiteSpace(Email)) return;
        try
        {
            // ── API CALL ──────────────────────────────────────────
            await Api.SubscribeAsync(Email);
        }
        catch { /* best-effort */ }
        Subscribed = true;
        Email = "";
    }
}
