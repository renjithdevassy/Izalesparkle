@page "/reset-password"
@inject IApiClient Api
@inject NavigationManager Nav

<PageTitle>Reset Password — Izale Sparkle</PageTitle>

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-brand">
            <a href="/" class="auth-logo">Izale <span class="gold">✦</span> Sparkle</a>
            <div class="auth-tagline">Where Every Look Sparkles</div>
        </div>

        <h1 class="auth-title">Reset Password</h1>
        <p class="auth-subtitle">Choose a new password for your account</p>

        @if (Done)
        {
            <div class="auth-success">✓ @InfoMsg</div>
            <div class="auth-links" style="justify-content:center">
                <a href="/login">Sign In →</a>
            </div>
        }
        else if (string.IsNullOrWhiteSpace(Token) || string.IsNullOrWhiteSpace(Email))
        {
            <div class="auth-error">⚠️ This reset link is invalid or incomplete. Please request a new one.</div>
            <div class="auth-links" style="justify-content:center">
                <a href="/forgot-password">Request New Link →</a>
            </div>
        }
        else
        {
            @if (!string.IsNullOrEmpty(ErrorMsg))
            {
                <div class="auth-error">⚠️ @ErrorMsg</div>
            }

            <div class="auth-form">
                <div class="auth-field">
                    <label>New Password</label>
                    <div class="auth-pass-wrap">
                        <input type="@(ShowPass ? "text" : "password")" autocomplete="new-password"
                               @bind="Password" placeholder="••••••••"
                               class="@(ShowErr && string.IsNullOrWhiteSpace(Password) ? "field-error" : "")" />
                        <button type="button" class="auth-pass-toggle"
                                @onclick="() => ShowPass = !ShowPass">
                            @(ShowPass ? "🙈" : "👁")
                        </button>
                    </div>
                </div>
                <div class="auth-field">
                    <label>Confirm New Password</label>
                    <input type="@(ShowPass ? "text" : "password")" autocomplete="new-password"
                           @bind="Confirm" placeholder="••••••••"
                           @onkeydown="OnKeyDown"
                           class="@(ShowErr && string.IsNullOrWhiteSpace(Confirm) ? "field-error" : "")" />
                </div>

                <button class="auth-submit-btn" @onclick="Submit" disabled="@Loading">
                    @(Loading ? "Resetting…" : "Reset Password ✦")
                </button>
            </div>

            <div class="auth-links" style="justify-content:center">
                <a href="/login">← Back to Sign In</a>
            </div>
        }
    </div>
</div>

@code {
    [SupplyParameterFromQuery] public string? Email { get; set; }
    [SupplyParameterFromQuery] public string? Token { get; set; }

    string Password = "";
    string Confirm  = "";
    string ErrorMsg = "";
    string InfoMsg  = "";
    bool   Loading  = false;
    bool   ShowErr  = false;
    bool   ShowPass = false;
    bool   Done     = false;

    async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await Submit();
    }

    async Task Submit()
    {
        ShowErr  = false;
        ErrorMsg = "";

        if (string.IsNullOrWhiteSpace(Password) || string.IsNullOrWhiteSpace(Confirm))
        { ShowErr = true; ErrorMsg = "Please enter and confirm your new password."; return; }

        if (Password.Length < 8)
        { ShowErr = true; ErrorMsg = "Password must be at least 8 characters."; return; }

        if (Password != Confirm)
        { ShowErr = true; ErrorMsg = "Passwords do not match."; return; }

        Loading = true;
        try
        {
            var result = await Api.ResetPasswordAsync(
                new ResetPasswordRequest(Email!, Token!, Password, Confirm));
            if (result?.Success == true)
            {
                Done    = true;
                InfoMsg = result.Message;
            }
            else ErrorMsg = result?.Message ?? "Unable to reset password. Please try again.";
        }
        catch { ErrorMsg = "Unable to connect. Please try again."; }
        finally { Loading = false; }
    }
}
