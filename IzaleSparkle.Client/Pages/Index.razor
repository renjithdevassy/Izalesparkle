@page "/"
@inject IApiClient Api
@inject ProductService FallbackSvc

<PageTitle>Izale Sparkle — Where Every Look Sparkles | Fine Jewellery UK</PageTitle>

<SeoMeta 
    IsHomepage="true"
/>

<!-- ══ HERO ══ -->
<section class="hero">
    <div class="hero-content">
        <div class="hero-eyebrow">
            <div class="eyebrow-line"></div>
            <span>New Sparkle Collection — 2026</span>
        </div>
        <h1 class="hero-title">
            <span class="hero-script">Where Every</span>
            Look <em>Sparkles.</em>
        </h1>
        <p class="hero-desc">Exquisite imitation jewellery inspired by Indian artistry, crafted for the woman who knows every outfit deserves to shine.</p>
        <div class="hero-btns">
            <a href="/shop" class="btn btn-dark btn-full-mobile">Shop Collection</a>
        </div>
        <div class="hero-stats">
            <div class="stat"><div class="stat-num">50+</div><div class="stat-label">Unique Pieces</div></div>
            <div class="stat"><div class="stat-num">100+</div><div class="stat-label">Happy Clients</div></div>
            <div class="stat"><div class="stat-num">100%</div><div class="stat-label">Conflict-Free</div></div>
        </div>
    </div>
    <div class="hero-img-mobile">
        <img src="https://images.unsplash.com/photo-1515562141207-7a88fb7ce338?w=900&q=85" alt="Izale Sparkle Fine Jewellery" loading="eager" fetchpriority="high" />
        <div class="hero-img-mobile-overlay"></div>
    </div>
    <div class="hero-img-side">
        <div class="hero-img-frame">
            <img src="https://images.unsplash.com/photo-1515562141207-7a88fb7ce338?w=900&q=85" alt="Izale Sparkle Fine Jewellery" loading="eager" />
            <div class="hero-sparkles">
                <span class="sparkle-dot s1">✦</span>
                <span class="sparkle-dot s2">✦</span>
                <span class="sparkle-dot s3">✦</span>
                <span class="sparkle-dot s4">✦</span>
            </div>
        </div>
    </div>
</section>

<!-- ══ MARQUEE ══ -->
<div class="marquee-bar" aria-hidden="true">
    <div class="marquee-track">
        @foreach (var item in MarqueeItems.Concat(MarqueeItems))
        {
            <span class="marquee-item">@item</span>
            <span class="marquee-sep">✦</span>
        }
    </div>
 </div>

<!-- ══ FEATURED PRODUCTS ══ -->
<section class="section bg-white">
    <div class="section-head">
        <span class="section-tag">✦ Featured ✦</span>
        <h2 class="section-title">New <em>Arrivals</em></h2>
        <div class="sparkle-divider"><span>✦</span></div>
 @*        <p class="section-subtitle">Each piece handcrafted with conflict-free stones and 18K gold.</p> *@
    </div>
    @if (Loading)
    {
        <div class="loading-screen" style="min-height:300px">
            <div class="loading-spinner">✦</div>
        </div>
    }
    else
    {
        <div class="product-grid grid-4">
            @foreach (var (product, idx) in Featured.Select((p, i) => (p, i)))
            {
                <ProductCard Summary="@product" DelayMs="@(idx * 80)" />
            }
        </div>
        <div class="section-cta">
            <a href="/shop" class="btn btn-outline">View All Pieces</a>
        </div>
    }
</section>

<!-- ══ TESTIMONIALS ══ -->
<section class="section bg-cream">
    <div class="section-head">
        <span class="section-tag">✦ Reviews ✦</span>
        <h2 class="section-title">She Said <em>Sparkle</em></h2>
        <div class="sparkle-divider"><span>✦</span></div>
    </div>
    <div class="testi-scroll">
        <div class="testi-grid">
            @foreach (var t in Testimonials)
            {
                <div class="testi-card">
                    <div class="testi-stars">★★★★★</div>
                    <div class="testi-quote">"</div>
                    <div class="testi-text">@t.Text</div>
                    <div class="testi-name">— @t.Author</div>
                </div>
            }
        </div>
    </div>
</section>

<!-- ══ NEWSLETTER ══ -->
<div class="newsletter-strip">
    <h3>Join the <em>Sparkle</em> Circle</h3>
    <p>Early access to new arrivals, exclusive events &amp; jewellery care tips.</p>
    <div class="newsletter-form">
        <input class="newsletter-input" type="email" inputmode="email" autocomplete="email"
               placeholder="Your email address" @bind="EmailInput" />
        <button class="newsletter-submit" @onclick="SubscribeAsync">Subscribe</button>
    </div>
    @if (!string.IsNullOrEmpty(SubscribeMsg))
    {
        <p style="color:#f0d080;margin-top:.8rem;font-size:.8rem">@SubscribeMsg</p>
    }
</div>

@code {
    bool Loading = true;
    List<ProductSummaryResponse> Featured = new();
    string EmailInput = "";
    string SubscribeMsg = "";

    record TestiItem(string Text, string Author);

    List<string> MarqueeItems = new()
    { "Izale Sparkle","Izale Sparkle","Izale Sparkle","Izale Sparkle" };

    List<TestiItem> Testimonials = new()
    {
        new("Simple and elegant. The quality feels really good for the price.", "Lakshmi Prasad, United Kingdom"),
        new("Very nice shine and neat design. Happy with the quality.", "Julie Koshy, United Kingdom"),
        
    };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // ── API CALL ──────────────────────────────────────────
            var result = await Api.GetFeaturedAsync(4);
            Featured = result?.ToList() ?? new();
        }
        catch
        {
            // Offline / API unavailable — fall back to in-memory data
            Featured = FallbackSvc.GetFeatured(4)
                .Select(p => new ProductSummaryResponse(p.Id, p.Name, p.Name.ToLower().Replace(" ","-"),
                    p.Material, p.Price, p.OldPrice, p.Category, p.Badge,
                    p.Stars, p.ImageUrl, p.IsOnSale, p.SavePercent)).ToList();
        }
        finally { Loading = false; }
    }

    async Task SubscribeAsync()
    {
        if (string.IsNullOrWhiteSpace(EmailInput)) return;
        try
        {
            // ── API CALL ──────────────────────────────────────────
            var result = await Api.SubscribeAsync(EmailInput);
            SubscribeMsg = result?.Data?.Message ?? "✦ Welcome to the Sparkle Circle!";
        }
        catch
        {
            SubscribeMsg = "✦ Welcome to the Sparkle Circle!";
        }
        EmailInput = "";
    }
}
