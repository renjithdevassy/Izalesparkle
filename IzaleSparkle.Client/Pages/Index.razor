@page "/"
@inject IApiClient Api
@inject ProductService FallbackSvc

<PageTitle>Izale Sparkle — Where Every Look Sparkles | Fine Jewellery UK</PageTitle>

<SeoMeta IsHomepage="true" />

<!-- ══ COMPACT HEADER ══ -->
<section class="page-hero" style="min-height:26vh">
    <span class="page-hero-tag">✦ Fine Imitation Jewellery · UK ✦</span>
    <h1 class="page-hero-title">Where Every Look <em>Sparkles</em></h1>
    <p class="page-hero-sub">Imitation jewellery inspired by Indian artistry — because every outfit deserves to shine.</p>
</section>

<!-- ══ MARQUEE ══ -->
<div class="marquee-bar" aria-hidden="true">
    <div class="marquee-track">
        @foreach (var item in MarqueeItems.Concat(MarqueeItems))
        {
            <span class="marquee-item">@item</span>
            <span class="marquee-sep">✦</span>
        }
    </div>
</div>

<!-- ══ FEATURED PRODUCTS ══ -->
<section class="section bg-white">
    <div class="section-head reveal">
        <span class="section-tag">✦ Shop Now ✦</span>
        <h2 class="section-title">Our <em>Pieces</em></h2>
        <div class="sparkle-divider"><span>✦</span></div>
        <p class="section-subtitle">Handpicked pieces inspired by Indian artistry — each one crafted to turn heads.</p>
    </div>
    @if (Loading)
    {
        <div class="loading-screen" style="min-height:300px">
            <div class="loading-spinner">✦</div>
        </div>
    }
    else
    {
        <div class="product-grid grid-4">
            @foreach (var (product, idx) in Featured.Select((p, i) => (p, i)))
            {
                <ProductCard Summary="@product" DelayMs="@(idx * 80)" />
            }
        </div>
        <div class="section-cta">
            <a href="/shop" class="btn btn-dark">View All Pieces</a>
        </div>
    }
</section>

<!-- ══ USP BAR ══ -->
<div class="usp-bar">
    <div class="usp-item reveal">
        <div class="usp-icon">🔁</div>
        <div class="usp-title">Easy Returns</div>
        <div class="usp-desc">30-day hassle-free returns</div>
    </div>
    <div class="usp-item reveal">
        <div class="usp-icon">💎</div>
        <div class="usp-title">Quality Assured</div>
        <div class="usp-desc">Every piece handpicked &amp; inspected</div>
    </div>
    <div class="usp-item reveal">
        <div class="usp-icon">🪙</div>
        <div class="usp-title">Affordable Indian Jewellery</div>
        <div class="usp-desc">Authentic craftsmanship, UK prices</div>
    </div>
    <div class="usp-item reveal">
        <div class="usp-icon">✨</div>
        <div class="usp-title">Exciting New Arrivals</div>
        <div class="usp-desc">Fresh styles added regularly</div>
    </div>
</div>

<!-- ══ EDITORIAL STRIP ══ -->
<div class="editorial-strip">
    <div class="editorial-img reveal-left">
        <img src="https://images.unsplash.com/photo-1535632066927-ab7c9ab60908?w=900&q=80" alt="Izale Sparkle craftsmanship" loading="lazy" />
    </div>
    <div class="editorial-content reveal-right">
        <p class="editorial-tag">Our Promise</p>
        <h2 class="editorial-title">Indian Artistry.<br /><em>Modern Elegance.</em></h2>
        <p class="editorial-body">Rooted in the rich tradition of Indian jewellery craftsmanship, every Izale Sparkle piece is carefully curated to bring you timeless beauty at an accessible price — so you can shine at every occasion.</p>
        <a href="/shop" class="btn btn-outline-light">Explore the Collection</a>
    </div>
</div>

<!-- ══ TESTIMONIALS ══ -->
<section class="section bg-cream">
    <div class="section-head reveal">
        <span class="section-tag">✦ Customer Reviews ✦</span>
        <h2 class="section-title">What Our Clients <em>Say</em></h2>
        <div class="sparkle-divider"><span>✦</span></div>
    </div>
    <div class="testi-scroll">
        <div class="testi-grid">
            @foreach (var t in Testimonials)
            {
                <div class="testi-card reveal">
                    <div class="testi-stars">★★★★★</div>
                    <div class="testi-quote">"</div>
                    <div class="testi-text">@t.Text</div>
                    <div class="testi-name">— @t.Author</div>
                </div>
            }
        </div>
    </div>
</section>

<!-- ══ NEWSLETTER ══ -->
<div class="newsletter-strip reveal">
    <h3>Join the <em>Sparkle</em> Circle</h3>
    <p>Be the first to hear about new arrivals, exclusive offers &amp; jewellery style tips.</p>
    <div class="newsletter-form">
        <input class="newsletter-input" type="email" inputmode="email" autocomplete="email"
               placeholder="Your email address" @bind="EmailInput" />
        <button class="newsletter-submit" @onclick="SubscribeAsync">Subscribe</button>
    </div>
    @if (!string.IsNullOrEmpty(SubscribeMsg))
    {
        <p style="color:#f0d080;margin-top:.8rem;font-size:.8rem">@SubscribeMsg</p>
    }
</div>

@code {
    bool Loading = true;
    List<ProductSummaryResponse> Featured = new();
    string EmailInput = "";
    string SubscribeMsg = "";

    record TestiItem(string Text, string Author);

    List<string> MarqueeItems = new()
    {
        "Handcrafted Jewellery", "UK Based", "Conflict-Free Stones",
        "Indian Artistry", "Modern Elegance", "Affordable Indian Jewellery", "Exciting New Arrivals"
    };

    List<TestiItem> Testimonials = new()
    {
        new("Simple and elegant. The quality feels really good for the price.", "Lakshmi Prasad, United Kingdom"),
        new("Very nice shine and neat design. Happy with the quality.", "Julie Koshy, United Kingdom"),
    };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var result = await Api.GetFeaturedAsync(24);
            Featured = result?.ToList() ?? new();
        }
        catch { }

        // Fall back to the local product list if the API returned nothing.
        if (!Featured.Any())
        {
            Featured = FallbackSvc.GetFeatured(24)
                .Select(p => new ProductSummaryResponse(p.Id, p.Name, p.Name.ToLower().Replace(" ", "-"),
                    p.Material, p.Price, p.OldPrice, p.Category, p.Badge,
                    p.Stars, p.ImageUrl, p.IsOnSale, p.SavePercent)).ToList();
        }

        Loading = false;
    }

    async Task SubscribeAsync()
    {
        if (string.IsNullOrWhiteSpace(EmailInput)) return;
        try
        {
            var result = await Api.SubscribeAsync(EmailInput);
            SubscribeMsg = result?.Data?.Message ?? "✦ Welcome to the Sparkle Circle!";
        }
        catch
        {
            SubscribeMsg = "✦ Welcome to the Sparkle Circle!";
        }
        EmailInput = "";
    }
}
