@page "/contact"
@inject IApiClient Api

<PageTitle>Contact — Izale Sparkle</PageTitle>

<!-- HERO -->
<div class="contact-hero">
    <div class="ch-deco" style="width:500px;height:500px"></div>
    <div class="ch-deco" style="width:300px;height:300px;opacity:0.5"></div>
    <div class="ch-content">
        <span class="ch-tag">Get In Touch</span>
        <h1 class="ch-title">Let's Make<br /><em>Your Look Sparkle.</em></h1>
        <p class="ch-sub">We'd love to hear from you. Every enquiry is answered within one business day.</p>
    </div>
</div>

<!-- CONTACT GRID -->
<div class="contact-grid">

    <!-- INFO PANEL -->
    <div class="ci-panel">
        <div class="ci-block">
            <div class="ci-label">Visit Us</div>
            <div class="ci-title">Our Showroom</div>
            <div class="ci-text">24 Hatton Garden<br />London EC1N 8DB<br />United Kingdom</div>
        </div>
        <div class="ci-block">
            <div class="ci-label">Get in Touch</div>
            <div class="ci-title">Contact Details</div>
            <div class="ci-text">
                Phone: <a href="tel:+442071234567" style="color:var(--gold)">+44 20 7123 4567</a><br />
                Email: <a href="mailto:hello@izalesparkle.com" style="color:var(--gold)">hello@izalesparkle.com</a><br />
                Bespoke: <a href="mailto:bespoke@izalesparkle.com" style="color:var(--gold)">bespoke@izalesparkle.com</a>
            </div>
        </div>
        <div class="ci-block">
            <div class="ci-label">Opening Hours</div>
            <div class="ci-title">Visit Us</div>
            <div class="hours-grid">
                @foreach (var h in Hours)
                {
                    <div class="hours-day">@h.Day</div>
                    <div class="hours-time">@h.Time</div>
                }
            </div>
        </div>
        <div class="ci-block" style="border-bottom:none">
            <div class="ci-label" style="margin-bottom:0.8rem">Follow Us</div>
            <div class="social-row">
                <a class="social-link" href="#">f</a>
                <a class="social-link" href="#">◎</a>
                <a class="social-link" href="#">𝕏</a>
                <a class="social-link" href="#">in</a>
            </div>
        </div>
    </div>

    <!-- FORM PANEL -->
    <div class="cf-panel">
        @if (Submitted)
        {
            <div class="form-success">
                <div class="form-success-icon">✦</div>
                <h3>Message Received!</h3>
                <p>Thank you for reaching out. A member of the Izale Sparkle team will respond within one business day.</p>
                <button class="btn btn-outline-gold" style="margin-top:1.5rem" @onclick="() => Submitted = false">Send Another Message</button>
            </div>
        }
        else
        {
            <div class="cf-title">Send a Message</div>
            <p class="cf-sub">Whether it's a general enquiry, a bespoke order, or just to say hello — we respond to every message within one business day.</p>

            <div class="f-row">
                <div class="f-field">
                    <label>First Name *</label>
                    <input type="text" @bind="FirstName" placeholder="Your first name"
                           class="@(ShowErrors && string.IsNullOrWhiteSpace(FirstName) ? "field-error" : "")" />
                </div>
                <div class="f-field">
                    <label>Last Name</label>
                    <input type="text" @bind="LastName" placeholder="Your last name" />
                </div>
            </div>
            <div class="f-row full">
                <div class="f-field">
                    <label>Email Address *</label>
                    <input type="email" @bind="Email" placeholder="you@example.com"
                           class="@(ShowErrors && string.IsNullOrWhiteSpace(Email) ? "field-error" : "")" />
                </div>
            </div>
            <div class="f-row full">
                <div class="f-field">
                    <label>Phone (optional)</label>
                    <input type="tel" @bind="Phone" placeholder="+44 7700 900000" />
                </div>
            </div>
            <div class="f-row full">
                <div class="f-field">
                    <label>Enquiry Type</label>
                    <select @bind="EnquiryType">
                        <option>General Enquiry</option>
                        <option>Bespoke Consultation</option>
                        <option>Order Query</option>
                        <option>Returns &amp; Repairs</option>
                        <option>Press &amp; Wholesale</option>
                    </select>
                </div>
            </div>
            <div class="f-row full">
                <div class="f-field">
                    <label>Your Message *</label>
                    <textarea rows="5" @bind="Message" placeholder="Tell us how we can help you sparkle..."
                              class="@(ShowErrors && string.IsNullOrWhiteSpace(Message) ? "field-error" : "")"></textarea>
                </div>
            </div>

            @if (ShowErrors)
            {
                <div class="form-error-msg">Please fill in all required fields.</div>
            }

            <button class="btn btn-dark" style="width:100%;height:50px;margin-top:0.5rem" @onclick="SubmitForm" disabled="@Submitting">
                @(Submitting ? "Sending…" : "Send Message ✦")
            </button>
            <p style="font-size:0.63rem;color:var(--warm-gray);text-align:center;margin-top:1rem;line-height:1.7">
                We respect your privacy. Your information is never shared with third parties.
            </p>
        }
    </div>
</div>

<!-- MAP SECTION -->
<div class="map-section">
    <div class="map-bg"></div>
    <div class="map-pin-wrap">
        <div class="map-pin-icon">📍</div>
        <div class="map-pin-name">Izale Sparkle</div>
        <div class="map-pin-addr">24 Hatton Garden, London EC1N 8DB</div>
    </div>
</div>

@code {
    string FirstName = "", LastName = "", Email = "", Phone = "", Message = "";
    string EnquiryType = "General Enquiry";
    bool Submitted = false;
    bool ShowErrors = false;

    record HourItem(string Day, string Time);

    List<HourItem> Hours = new()
    {
        new("Monday – Friday", "10:00 – 18:00"),
        new("Saturday",        "10:00 – 17:00"),
        new("Sunday",          "By appointment"),
        new("Bank Holidays",   "Closed"),
    };

    bool Submitting = false;

    async Task SubmitForm()
    {
        ShowErrors = false;
        if (string.IsNullOrWhiteSpace(FirstName) || string.IsNullOrWhiteSpace(Email) || string.IsNullOrWhiteSpace(Message))
        { ShowErrors = true; return; }

        Submitting = true;
        try
        {
            // ── API CALL ──────────────────────────────────────────
            await Api.SendContactAsync(new IzaleSparkle.Contracts.Requests.ContactRequest(
                FirstName, LastName, Email, Phone, EnquiryType, Message));
        }
        catch { /* best-effort — show success regardless */ }
        finally { Submitting = false; }

        Submitted = true;
    }
}
