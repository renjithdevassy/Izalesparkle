{
  "version": "0.2.0",
  "configurations": [
    {
      // ── OPTION 1: Full Blazor WASM + Server debugging in VS Code ──────────
      // Starts the server AND attaches the browser WASM debugger.
      // Breakpoints work in both .razor / .cs Client files AND Server/API files.
      "name": "Launch & Debug (Blazor WASM Hosted)",
      "type": "blazorwasm",
      "request": "launch",
      "hosted": true,
      "program": "${workspaceFolder}/IzaleSparkle.Server/IzaleSparkle.Server.csproj",
      "cwd": "${workspaceFolder}/IzaleSparkle.Server",
      "browser": "chrome",
      "url": "https://localhost:7000",
      "preLaunchTask": "build-server"
    },
    {
      // ── OPTION 2: Attach to already-running server ──────────────────────
      // Use when you've already started the server with: dotnet run
      "name": "Attach to Blazor WASM (already running)",
      "type": "blazorwasm",
      "request": "attach",
      "url": "https://localhost:7000"
    },
    {
      // ── OPTION 3: Server-only (API breakpoints only) ──────────────────────
      // Use this when you only need to debug controller/service code.
      "name": "Debug Server (API only)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-server",
      "program": "${workspaceFolder}/IzaleSparkle.Server/bin/Debug/net10.0/IzaleSparkle.Server.dll",
      "args": [],
      "cwd": "${workspaceFolder}/IzaleSparkle.Server",
      "stopAtEntry": false,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      },
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    }
  ]
}
